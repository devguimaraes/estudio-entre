---
import GaleriaEspaco from "@/components/islands/GaleriaEspaco";
---

<section class="espaco" id="espaco" aria-label="Galeria do espaço do Estúdio Entre">
  <div class="espaco__header">
    <p class="espaco__eyebrow">Espaço</p>
    <h2 class="espaco__title">Onde tudo acontece</h2>
  </div>

  <GaleriaEspaco client:visible />

  <script>
    import { animateEspaco } from "@/animations/espaco";
    animateEspaco();
  </script>
</section>

<style>
  /* ============================
     Espaço — BEM scoped styles
     ============================ */

  .espaco {
    position: relative;
    background-color: var(--color-cream);
    color: var(--color-near-black);
    padding: 8rem 0;
    overflow: hidden;
  }

  /* --- Header --- */

  .espaco__header {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 4rem 3rem;
    opacity: 0;
  }

  .espaco__eyebrow {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--color-near-black);
    opacity: 0.5;
    margin-bottom: 1rem;
  }

  .espaco__title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.1;
    color: var(--color-near-black);
  }

  /* --- Gallery wrapper (island) --- */

  .espaco :global(.espaco__gallery-wrapper) {
    position: relative;
    z-index: 2;
  }

  /* --- Gallery horizontal scroll --- */

  .espaco :global(.espaco__gallery) {
    display: flex;
    gap: 1.25rem;
    overflow-x: auto;
    padding: 0 4rem 1.5rem;
    cursor: grab;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    touch-action: pan-x;
  }

  .espaco :global(.espaco__gallery:active) {
    cursor: grabbing;
  }

  .espaco :global(.espaco__gallery::-webkit-scrollbar) {
    display: none;
  }

  /* --- Foto card --- */

  .espaco :global(.espaco__foto) {
    flex-shrink: 0;
    width: 340px;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-align: left;
    color: var(--color-near-black);
  }

  .espaco :global(.espaco__foto-image-wrapper) {
    position: relative;
    aspect-ratio: 5 / 4;
    overflow: hidden;
    border-radius: 6px;
  }

  .espaco :global(.espaco__foto-image) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(20%) contrast(1.1);
    transition: filter 0.5s ease;
  }

  .espaco :global(.espaco__foto:hover .espaco__foto-image) {
    filter: none;
  }

  /* --- Halftone overlay --- */

  .espaco :global(.espaco__foto-halftone) {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 0.5;
    mix-blend-mode: multiply;
    transition: opacity 0.5s ease;
  }

  .espaco :global(.espaco__foto:hover .espaco__foto-halftone) {
    opacity: 0;
  }

  /* --- Legenda --- */

  .espaco :global(.espaco__foto-legenda) {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-style: italic;
    color: var(--color-text-muted);
    padding: 0 0.25rem;
  }

  /* --- Progress bar --- */

  .espaco :global(.espaco__progress) {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 4rem;
    height: 2px;
    background-color: rgba(26, 22, 18, 0.1);
    border-radius: 1px;
  }

  .espaco :global(.espaco__progress-bar) {
    height: 100%;
    background-color: var(--color-orange);
    border-radius: 1px;
    transform-origin: left;
    transition: transform 0.1s ease;
  }

  /* ============================
     Tablet (max-width: 1024px)
     ============================ */

  @media (max-width: 1024px) {
    .espaco {
      padding: 5rem 0;
    }

    .espaco__header {
      padding: 0 2rem 2.5rem;
    }

    .espaco :global(.espaco__gallery) {
      padding: 0 2rem 1.5rem;
    }

    .espaco :global(.espaco__foto) {
      width: 280px;
    }

    .espaco :global(.espaco__progress) {
      padding: 0 2rem;
    }
  }

  /* ============================
     Mobile (max-width: 768px)
     ============================ */

  @media (max-width: 768px) {
    .espaco {
      padding: 4rem 0;
    }

    .espaco__header {
      padding: 0 1.5rem 2rem;
    }

    .espaco :global(.espaco__gallery) {
      gap: 1rem;
      padding: 0 1.5rem 1.5rem;
    }

    .espaco :global(.espaco__foto) {
      width: 85vw;
    }

    .espaco :global(.espaco__progress) {
      padding: 0 1.5rem;
    }
  }

  /* ============================
     Reduced motion
     ============================ */

  @media (prefers-reduced-motion: reduce) {
    .espaco :global(.espaco__foto-image) {
      filter: none;
      transition: none;
    }

    .espaco :global(.espaco__foto-halftone) {
      opacity: 0;
      transition: none;
    }

    .espaco :global(.espaco__progress-bar) {
      transition: none;
    }
  }
</style>
