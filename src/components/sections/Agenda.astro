---
import AgendaFilter from "@/components/islands/AgendaFilter";
import type { EventoCard } from "@/types/evento";

interface Props {
  eventos: EventoCard[];
}

const { eventos } = Astro.props;
---

<section class="agenda" id="agenda" aria-label="Agenda de eventos do Estúdio Entre">
  <div class="agenda__header">
    <p class="agenda__eyebrow">Agenda</p>
    <h2 class="agenda__title">Próximos encontros</h2>
  </div>

  {eventos.length > 0 ? (
    <AgendaFilter client:visible eventos={eventos} />
  ) : (
    <div class="agenda__empty">
      <p class="agenda__empty-text">
        Nenhum evento cadastrado por enquanto — mas tem coisa vindo por aí.
      </p>
      <a
        href="https://instagram.com/estudioentre"
        target="_blank"
        rel="noopener noreferrer"
        class="agenda__empty-cta"
        data-cursor="SEGUIR"
      >
        Acompanhe no Instagram
      </a>
    </div>
  )}

  <script>
    import { animateAgenda } from "@/animations/agenda";
    animateAgenda();
  </script>
</section>

<style>
  /* ============================
     Agenda — BEM scoped styles
     ============================ */

  .agenda {
    position: relative;
    background-color: var(--color-olive);
    color: var(--color-cream);
    padding: 8rem 0;
    overflow: hidden;
  }

  /* --- Header --- */

  .agenda__header {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 4rem 3rem;
    opacity: 0;
  }

  .agenda__eyebrow {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--color-cream);
    opacity: 0.7;
    margin-bottom: 1rem;
  }

  .agenda__title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.1;
    color: var(--color-cream);
  }

  /* --- Content (island wrapper) --- */

  .agenda :global(.agenda__content) {
    position: relative;
    z-index: 2;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 4rem;
  }

  /* --- Filters --- */

  .agenda :global(.agenda__filters) {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 3rem;
  }

  .agenda :global(.agenda__pill) {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.5rem 1.25rem;
    border-radius: 999px;
    border: 1px solid rgba(240, 237, 232, 0.2);
    background: transparent;
    color: var(--color-cream);
    opacity: 0.7;
    cursor: pointer;
    transition:
      opacity 0.3s ease,
      border-color 0.3s ease,
      background-color 0.3s ease;
  }

  .agenda :global(.agenda__pill:hover) {
    opacity: 1;
    border-color: rgba(240, 237, 232, 0.4);
  }

  .agenda :global(.agenda__pill--active) {
    opacity: 1;
    background-color: var(--pill-color, var(--color-cream));
    border-color: var(--pill-color, var(--color-cream));
    color: var(--pill-text, var(--color-cream));
  }

  /* --- Grid --- */

  .agenda :global(.agenda__grid) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  /* --- Empty state --- */

  .agenda__empty {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 4rem 2rem;
  }

  .agenda__empty-text {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: var(--color-cream);
    opacity: 0.8;
    margin-bottom: 2rem;
  }

  .agenda__empty-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 2rem;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    background-color: var(--color-cream);
    color: var(--color-olive);
    border-radius: 4px;
    transition:
      transform 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      background-color 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .agenda__empty-cta:hover {
    transform: translateX(6px);
    background-color: white;
  }

  /* ============================
     Tablet (max-width: 1024px)
     ============================ */

  @media (max-width: 1024px) {
    .agenda {
      padding: 5rem 0;
    }

    .agenda__header {
      padding: 0 2rem 2.5rem;
    }

    .agenda :global(.agenda__content) {
      padding: 0 2rem;
    }

    .agenda :global(.agenda__grid) {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ============================
     Mobile (max-width: 768px)
     ============================ */

  @media (max-width: 768px) {
    .agenda {
      padding: 4rem 0;
    }

    .agenda__header {
      padding: 0 1.5rem 2rem;
    }

    .agenda :global(.agenda__content) {
      padding: 0 1.5rem;
    }

    .agenda :global(.agenda__grid) {
      grid-template-columns: 1fr;
    }

    .agenda :global(.agenda__filters) {
      flex-wrap: nowrap;
      overflow-x: auto;
      justify-content: flex-start;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-bottom: 0.5rem;
    }

    .agenda :global(.agenda__filters::-webkit-scrollbar) {
      display: none;
    }

    .agenda__empty-cta {
      width: 100%;
      justify-content: center;
    }
  }

  /* ============================
     Reduced motion
     ============================ */

  @media (prefers-reduced-motion: reduce) {
    .agenda__empty-cta {
      transition: none;
    }
  }
</style>
