---
// Sobre.astro — Seção editorial do Estúdio Entre
// Astro puro com CSS scoped. Animações GSAP via módulo separado.
---

<section class="sobre" id="sobre" aria-label="Sobre o Estúdio Entre">
  <!-- Textura papel -->
  <div class="sobre__texture-paper" aria-hidden="true"></div>

  <!-- Grid de conteúdo -->
  <div class="sobre__grid">
    <!-- Lado do texto (esquerda, 60%) -->
    <div class="sobre__content">
      <p class="sobre__eyebrow">Nossa História</p>
      <h2 class="sobre__title">Uma mãe, uma filha e um sonho.</h2>
      <p class="sobre__text">
        O Estúdio Entre é um hub cultural multidisciplinar, cuja missão é promover encontros significativos entre cultura, conhecimento e bem-estar. Um espaço plural e acolhedor, onde arte, palavra e cuidado se entrelaçam para inspirar conexões.
      </p>
      <p class="sobre__text">
        Por meio de experiências que unem literatura, comunicação e práticas integrativas, estimula a escuta, a criação e o acesso à expressão cultural em suas diversas formas — fortalecendo o vínculo entre pessoas, gerações e modos de existir.
      </p>
      <p class="sobre__text">
        O hub reúne rodas de biblioterapia, oficinas, palestras e encontros culturais, além de disponibilizar um estúdio com estrutura profissional para gravação de sets, podcasts e videocasts.
      </p>
      <p class="sobre__signature">
        Assim nasce o Estúdio Entre: entre palavras, entre pessoas — é só entrar.
      </p>
    </div>

    <!-- Lado da foto (direita, 40%) -->
    <div class="sobre__photo-side">
      <div class="sobre__photo-wrapper" data-cursor="VER DE PERTO">
        <img
          class="sobre__photo"
          src="/images/sobre-placeholder-1.webp"
          alt="Espaço do Estúdio Entre — hub cultural no Méier"
          width="600"
          height="800"
          loading="lazy"
        />
        <div class="sobre__photo-halftone" aria-hidden="true">
          <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
            <filter id="halftone-sobre">
              <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" />
            </filter>
            <rect width="100%" height="100%" filter="url(#halftone-sobre)" />
          </svg>
        </div>
      </div>
    </div>
  </div>

  <!-- Decoração flutuante (olho/chave) -->
  <div class="sobre__decoration" aria-hidden="true">
    <img src="/icons/olho.svg" alt="" width="120" height="83" />
  </div>

  <script>
    import { animateSobre } from "@/animations/sobre";
    animateSobre();
  </script>
</section>

<style>
  /* ============================
     Sobre — BEM scoped styles
     ============================ */

  .sobre {
    position: relative;
    background-color: var(--color-cream);
    color: var(--color-near-black);
    padding: 8rem 4rem;
    overflow: hidden;
  }

  /* --- Textura papel --- */

  .sobre__texture-paper {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background-image: url("/textures/paper-texture-optimized.webp");
    background-repeat: repeat;
    background-size: cover;
    opacity: 0.08;
  }

  /* --- Grid --- */

  .sobre__grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 6fr 4fr;
    gap: 4rem;
    max-width: 1400px;
    margin: 0 auto;
    align-items: center;
  }

  /* --- Content side --- */

  .sobre__content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* --- Eyebrow --- */

  .sobre__eyebrow {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--color-bordo);
    opacity: 0;
  }

  /* --- Title --- */

  .sobre__title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.1;
    color: var(--color-near-black);
    opacity: 0;
  }

  /* --- Text paragraphs --- */

  .sobre__text {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: clamp(1rem, 2vw, 1.125rem);
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 540px;
    opacity: 0;
  }

  /* --- Signature --- */

  .sobre__signature {
    font-family: var(--font-body);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(1.125rem, 2.5vw, 1.375rem);
    line-height: 1.5;
    color: var(--color-bordo);
    margin-top: 1rem;
    opacity: 0;
  }

  /* --- Photo side --- */

  .sobre__photo-side {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sobre__photo-wrapper {
    position: relative;
    width: 100%;
    max-width: 480px;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: 4px;
    cursor: pointer;
  }

  .sobre__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* --- Halftone overlay --- */

  .sobre__photo-halftone {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    mix-blend-mode: multiply;
    opacity: 0.7;
    transition: opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .sobre__photo-wrapper:hover .sobre__photo-halftone {
    opacity: 0;
  }

  /* --- Floating decoration --- */

  .sobre__decoration {
    position: absolute;
    bottom: 5%;
    left: 5%;
    z-index: 3;
    opacity: 0.06;
    pointer-events: none;
  }

  .sobre__decoration img {
    width: 120px;
    height: auto;
  }

  /* ============================
     Tablet (max-width: 1024px)
     ============================ */

  @media (max-width: 1024px) {
    .sobre {
      padding: 5rem 2rem;
    }

    .sobre__grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .sobre__photo-side {
      order: -1;
    }

    .sobre__content {
      align-items: center;
      text-align: center;
    }

    .sobre__text {
      max-width: 100%;
    }
  }

  /* ============================
     Mobile (max-width: 768px)
     ============================ */

  @media (max-width: 768px) {
    .sobre {
      padding: 4rem 1.5rem;
    }

    .sobre__photo-wrapper {
      max-width: 100%;
    }

    .sobre__decoration {
      display: none;
    }
  }

  /* ============================
     Reduced motion
     ============================ */

  @media (prefers-reduced-motion: reduce) {
    .sobre__photo-halftone {
      transition: none;
    }
  }
</style>
