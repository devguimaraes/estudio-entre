---
import logoClara from "@/assets/logos/Logo_Estudio Entre - Claro 1.png";
---

<footer class="footer" id="footer" aria-label="Rodapé do Estúdio Entre">
  <div class="footer__main">
    <!-- Logo centralizada -->
    <div class="footer__brand">
      <img
        class="footer__logo"
        src={logoClara.src}
        alt="Estúdio Entre"
        width="200"
        height="auto"
        loading="lazy"
      />
      <p class="footer__tagline">
        Hub cultural independente no Méier, Rio de Janeiro
      </p>
    </div>

    <!-- Grid 3 colunas -->
    <div class="footer__grid">
      <!-- Coluna 1: Menu -->
      <nav class="footer__nav" aria-label="Menu do rodapé">
        <h3 class="footer__heading">Navegação</h3>
        <ul class="footer__nav-list" role="list">
          <li>
            <a href="#sobre" class="footer__nav-link" data-cursor="ENTRAR"
              >Sobre</a
            >
          </li>
          <li>
            <a href="#eixos" class="footer__nav-link" data-cursor="ENTRAR"
              >Eixos</a
            >
          </li>
          <li>
            <a href="#agenda" class="footer__nav-link" data-cursor="ENTRAR"
              >Agenda</a
            >
          </li>
          <li>
            <a href="#espaco" class="footer__nav-link" data-cursor="ENTRAR"
              >Espaço</a
            >
          </li>
          <li>
            <a href="#contato" class="footer__nav-link" data-cursor="ENTRAR"
              >Contato</a
            >
          </li>
        </ul>
      </nav>

      <!-- Coluna 2: Contato -->
      <div class="footer__contact">
        <h3 class="footer__heading">Contato</h3>
        <address class="footer__address">
          Rua Maria Calmon, 100 — Méier<br />
          Rio de Janeiro – RJ, 20710-030
        </address>
        <a
          href="https://www.google.com/maps/dir/?api=1&destination=-22.8976,-43.2896"
          target="_blank"
          rel="noopener noreferrer"
          class="footer__map-link"
          data-cursor="VER MAPA"
        >
          <svg
            class="footer__map-icon"
            viewBox="0 0 24 24"
            width="16"
            height="16"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
            />
            <circle cx="12" cy="10" r="3" />
          </svg>
          Como chegar
        </a>
      </div>

      <!-- Coluna 3: Social -->
      <div class="footer__social">
        <h3 class="footer__heading">Siga a gente</h3>
        <div class="footer__social-links">
          <a
            href="https://www.instagram.com/entrenoestudio/"
            target="_blank"
            rel="noopener noreferrer"
            class="footer__social-link"
            aria-label="Instagram"
            data-cursor="INSTAGRAM"
          >
            <svg
              viewBox="0 0 24 24"
              width="20"
              height="20"
              fill="currentColor"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
              />
            </svg>
          </a>
          <a
            href="https://www.tiktok.com/@entrenoestudio"
            target="_blank"
            rel="noopener noreferrer"
            class="footer__social-link"
            aria-label="TikTok"
            data-cursor="TIKTOK"
          >
            <svg
              viewBox="0 0 24 24"
              width="20"
              height="20"
              fill="currentColor"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.46V13a8.28 8.28 0 005.58 2.15V11.7a4.83 4.83 0 01-3.77-1.24V6.69h3.77z"
              />
            </svg>
          </a>
          <a
            href="https://www.facebook.com/61583641444105"
            target="_blank"
            rel="noopener noreferrer"
            class="footer__social-link"
            aria-label="Facebook"
            data-cursor="FACEBOOK"
          >
            <svg
              viewBox="0 0 24 24"
              width="20"
              height="20"
              fill="currentColor"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
              />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Barra copyright -->
  <div class="footer__bar">
    <p class="footer__copyright">
      &copy; 2025 Estúdio Entre. Todos os direitos reservados.
    </p>
  </div>

  <script>
    import { animateFooter } from "@/animations/footer";
    animateFooter();
  </script>
</footer>

<style>
  /* ============================
     Footer — BEM scoped styles
     ============================ */

  .footer {
    position: relative;
    background-color: var(--color-near-black);
    color: var(--color-cream);
    overflow: hidden;
  }

  /* --- Main --- */

  .footer__main {
    max-width: 1400px;
    margin: 0 auto;
    padding: 6rem 4rem 4rem;
  }

  /* --- Brand --- */

  .footer__brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 4rem;
    text-align: center;
  }

  .footer__logo {
    width: 200px;
    height: auto;
  }

  .footer__tagline {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1rem;
    color: var(--color-cream);
    opacity: 0.6;
    max-width: 320px;
  }

  /* --- Grid --- */

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 3rem;
  }

  /* --- Heading --- */

  .footer__heading {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  /* --- Nav --- */

  .footer__nav-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer__nav-link {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 1rem;
    text-decoration: none;
    color: var(--color-cream);
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  .footer__nav-link:hover {
    opacity: 1;
  }

  /* --- Contact --- */

  .footer__address {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-cream);
    opacity: 0.8;
    font-style: normal;
    margin-bottom: 1rem;
  }

  .footer__map-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--color-cream);
    text-decoration: none;
    border-bottom: 1px solid rgba(240, 237, 232, 0.3);
    padding-bottom: 2px;
    transition:
      border-color 0.3s ease,
      opacity 0.3s ease;
  }

  .footer__map-link:hover {
    border-color: var(--color-cream);
    opacity: 0.8;
  }

  .footer__map-icon {
    width: 16px;
    height: 16px;
  }

  /* --- Social --- */

  .footer__social-links {
    display: flex;
    gap: 1rem;
  }

  .footer__social-link {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(240, 237, 232, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-cream);
    transition:
      border-color 0.3s ease,
      background-color 0.3s ease;
  }

  .footer__social-link:hover {
    border-color: rgba(240, 237, 232, 0.4);
    background-color: rgba(240, 237, 232, 0.08);
  }

  .footer__social-link svg {
    width: 20px;
    height: 20px;
  }

  /* --- Copyright bar --- */

  .footer__bar {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem 4rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .footer__copyright {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.8rem;
    color: var(--color-cream);
    opacity: 0.4;
    text-align: center;
  }

  /* ============================
     Tablet (max-width: 1024px)
     ============================ */

  @media (max-width: 1024px) {
    .footer__main {
      padding: 5rem 2rem 3rem;
    }

    .footer__bar {
      padding: 1.5rem 2rem;
    }
  }

  /* ============================
     Mobile (max-width: 768px)
     ============================ */

  @media (max-width: 768px) {
    .footer__main {
      padding: 4rem 1.5rem 2.5rem;
    }

    .footer__brand {
      margin-bottom: 3rem;
    }

    .footer__logo {
      width: 160px;
    }

    .footer__grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .footer__bar {
      padding: 1.5rem;
    }
  }

  /* ============================
     Reduced motion
     ============================ */

  @media (prefers-reduced-motion: reduce) {
    .footer__nav-link,
    .footer__map-link,
    .footer__social-link {
      transition: none;
    }
  }
</style>
