---
// Hero.astro — Seção principal do Estúdio Entre
// HTML estático com CSS scoped. Animações GSAP serão adicionadas depois.
---

<section class="hero" role="banner" aria-label="Estúdio Entre — Hub Cultural no Méier, RJ">
  <!-- Textura papel -->
  <div class="hero__texture-paper" aria-hidden="true"></div>

  <!-- Textura halftone -->
  <div class="hero__texture-halftone" aria-hidden="true">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <filter id="halftone">
        <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" />
      </filter>
      <rect width="100%" height="100%" filter="url(#halftone)" />
    </svg>
  </div>

  <!-- Grid de conteúdo -->
  <div class="hero__grid">
    <!-- Lado do conteúdo -->
    <div class="hero__content">
      <p class="hero__eyebrow">Hub Cultural &middot; M&eacute;ier RJ</p>

      <img
        class="hero__logo"
        src="/logos/Logo_Estudio Entre - Claro 2.webp"
        alt="Estúdio Entre"
        width="500"
        height="172"
        loading="eager"
        fetchpriority="high"
      />

      <p class="hero__tagline">
        <span class="hero__word">Entre</span>
        <span class="hero__word">livros,</span>
        <span class="hero__word">vozes</span>
        <span class="hero__word">e</span>
        <span class="hero__word">beats.</span>
      </p>

      <div class="hero__ctas">
        <a href="#agenda" class="hero__cta hero__cta--primary" data-cursor="ENTRAR">
          Próximos encontros
          <span class="hero__cta-arrow" aria-hidden="true">→</span>
        </a>
        <a href="#espaco" class="hero__cta hero__cta--secondary" data-cursor="VER">
          Conheça o espaço
          <span class="hero__cta-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>

    <!-- Lado gráfico (chave) -->
    <div class="hero__graphic" aria-hidden="true">
      <img
        class="hero__key"
        src="/icons/olho.svg"
        alt=""
        width="320"
        height="221"
      />
    </div>
  </div>

  <!-- Divisor central com glow -->
  <div class="hero__divider" aria-hidden="true"></div>

  <!-- Scroll indicator -->
  <div class="hero__scroll-indicator" aria-hidden="true">
    <span class="hero__scroll-text">Scroll</span>
    <span class="hero__scroll-line"></span>
  </div>

  <script>
    import { animateHero } from "@/animations/hero";
    animateHero();
  </script>
</section>

<style>
  /* ============================
     Hero — BEM scoped styles
     ============================ */

  .hero {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100vh;
    min-height: 100dvh;
    overflow: visible;
    background-color: var(--color-orange);
  }

  /* --- Texturas --- */

  .hero__texture-paper {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background-image: url("/textures/paper-texture-optimized.webp");
    background-repeat: repeat;
    background-size: cover;
    opacity: 0.08;
  }

  .hero__texture-halftone {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 0.12;
  }

  /* --- Grid --- */

  .hero__grid {
    position: relative;
    z-index: 2;
    display: contents;
  }

  /* --- Content side --- */

  .hero__content {
    grid-column: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 5rem 4rem;
  }

  /* --- Eyebrow --- */

  .hero__eyebrow {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--color-cream);
    opacity: 0;
    margin-bottom: 1.5rem;
  }

  /* --- Logo --- */

  .hero__logo {
    max-width: 500px;
    width: 100%;
    height: auto;
    filter: brightness(0) invert(1);
    opacity: 0;
    margin-bottom: 2rem;
  }

  /* --- Tagline --- */

  .hero__tagline {
    font-family: var(--font-body);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(1.125rem, 3.5vw, 1.5rem);
    color: var(--color-cream);
    max-width: 420px;
    line-height: 1.4;
    margin-bottom: 2.5rem;
  }

  /* --- Words (para animação SplitText futura) --- */

  .hero__word {
    display: inline-block;
    opacity: 0;
  }

  /* --- CTAs --- */

  .hero__ctas {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    opacity: 0;
    max-width: 260px;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1.1rem 2.2rem;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    border-radius: 4px;
    position: relative;
    overflow: hidden;
    transition:
      background-color 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      transform 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .hero__cta::before {
    content: "";
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(240, 237, 232, 0.2), transparent);
    transition: left 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .hero__cta:hover::before {
    left: 100%;
  }

  .hero__cta-arrow {
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .hero__cta:hover .hero__cta-arrow {
    transform: translateX(6px);
  }

  .hero__cta--primary {
    background-color: var(--color-cream);
    color: var(--color-orange);
  }

  .hero__cta--primary:hover {
    background-color: white;
    transform: translateX(8px);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.3);
  }

  .hero__cta--secondary {
    background-color: transparent;
    color: var(--color-cream);
    border: 2px solid var(--color-cream);
  }

  .hero__cta--secondary:hover {
    background-color: rgba(240, 237, 232, 0.1);
  }

  /* --- Graphic side (chave) --- */

  .hero__graphic {
    grid-column: 2;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero__key {
    width: 70%;
    height: auto;
    transform: translateX(-15%);
    opacity: 0.1;
  }

  /* --- Divisor central --- */

  .hero__divider {
    position: absolute;
    top: 10%;
    bottom: 10%;
    left: 50%;
    width: 1px;
    z-index: 3;
    background: linear-gradient(
      to bottom,
      transparent,
      var(--color-cream) 30%,
      var(--color-cream) 70%,
      transparent
    );
    box-shadow: 0 0 12px 2px rgba(240, 237, 232, 0.3);
    pointer-events: none;
  }

  /* --- Scroll indicator --- */

  .hero__scroll-indicator {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
  }

  .hero__scroll-text {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-cream);
  }

  .hero__scroll-line {
    display: block;
    width: 1px;
    height: 40px;
    background: var(--color-cream);
    animation: scrollFlow 2s ease-in-out infinite;
  }

  @keyframes scrollFlow {
    0% {
      transform: scaleY(0);
      transform-origin: top;
      opacity: 1;
    }
    50% {
      transform: scaleY(1);
      transform-origin: top;
      opacity: 1;
    }
    50.01% {
      transform-origin: bottom;
    }
    100% {
      transform: scaleY(0);
      transform-origin: bottom;
      opacity: 1;
    }
  }

  /* ============================
     Tablet (max-width: 1024px)
     ============================ */

  @media (max-width: 1024px) {
    .hero {
      grid-template-columns: 1fr;
    }

    .hero__content {
      grid-column: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 4rem 2rem;
    }

    .hero__graphic {
      display: none;
    }

    .hero__divider {
      display: none;
    }

    .hero__tagline {
      max-width: 480px;
    }

    .hero__ctas {
      align-items: center;
    }
  }

  /* ============================
     Mobile (max-width: 768px)
     ============================ */

  @media (max-width: 768px) {
    .hero__content {
      padding: 3rem 1.5rem;
    }

    .hero__logo {
      max-width: 280px;
    }

    .hero__tagline {
      font-size: clamp(1rem, 4vw, 1.25rem);
      max-width: 100%;
    }

    .hero__word {
      margin-right: 0.15em;
    }

    .hero__word:last-child {
      margin-right: 0;
    }

    .hero__cta {
      width: 100%;
      max-width: 100%;
      justify-content: center;
      font-size: 0.875rem;
      padding: 1rem 1.75rem;
    }

    .hero__ctas {
      max-width: 100%;
      gap: 0.875rem;
    }

    .hero__scroll-indicator {
      bottom: 1.5rem;
    }
  }

  /* ============================
     Reduced motion
     ============================ */

  @media (prefers-reduced-motion: reduce) {
    .hero__cta {
      transition: none;
    }

    .hero__scroll-line {
      animation: none;
    }
  }
</style>
