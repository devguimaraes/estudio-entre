---
import { sanityClient } from "sanity:client";
import BaseLayout from "@/layouts/BaseLayout.astro";

const EVENTOS_QUERY = `*[_type == "evento"]|order(dataHora desc){
  _id, titulo, "slug": slug.current, categoria, dataHora, local, valor, ativo
}`;

const CONFIG_QUERY = `*[_type == "configuracao"][0]{
  titulo, descricao, redesSociais
}`;

const [eventos, config] = await Promise.all([
  sanityClient.fetch(EVENTOS_QUERY),
  sanityClient.fetch(CONFIG_QUERY),
]);
---

<BaseLayout title="Teste Sanity — Estudio Entre">
  <main class="max-w-4xl mx-auto p-8">
    <h1 class="text-3xl font-bold mb-8">Teste de Conexao Sanity</h1>

    <section class="mb-12">
      <h2 class="text-2xl font-semibold mb-4">Configuracoes</h2>
      {config ? (
        <pre class="bg-gray-900 text-green-400 p-4 rounded-lg overflow-auto text-sm">{JSON.stringify(config, null, 2)}</pre>
      ) : (
        <p class="text-yellow-400">Nenhuma configuracao encontrada. Crie um documento "configuracao" no Sanity.</p>
      )}
    </section>

    <section>
      <h2 class="text-2xl font-semibold mb-4">Eventos ({eventos.length})</h2>
      {eventos.length > 0 ? (
        <pre class="bg-gray-900 text-green-400 p-4 rounded-lg overflow-auto text-sm">{JSON.stringify(eventos, null, 2)}</pre>
      ) : (
        <p class="text-yellow-400">Nenhum evento encontrado. Crie documentos "evento" no Sanity.</p>
      )}
    </section>
  </main>
</BaseLayout>
