---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Estúdio Entre — Hub Cultural no Méier, RJ">
  <main class="min-h-screen flex flex-col items-center justify-center px-6 text-center">
    <h1 class="font-serif text-5xl md:text-7xl lg:text-8xl tracking-tight mb-6">
      Estúdio Entre
    </h1>
    <p class="text-xl md:text-2xl max-w-2xl opacity-90 mb-8">
      Entre livros, vozes e beats.
    </p>
    <p class="text-sm opacity-60">
      Hub cultural e criativo independente — Méier, Rio de Janeiro
    </p>
  </main>
</BaseLayout>
