# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

# 2-space indentation for web files
[*.{js,jsx,ts,tsx,astro,vue,svelte,json,css,scss,less}]
indent_style = space
indent_size = 2

# Markdown
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# YAML
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# HTML
[*.html]
indent_style = space
indent_size = 2

# Shell scripts
[*.{sh,bash}]
indent_style = space
indent_size = 2

# Makefiles (requires tabs)
[Makefile]
indent_style = tab

# Python
[*.py]
indent_style = space
indent_size = 4

# Go
[*.go]
indent_style = tab

# Java
[*.java]
indent_style = space
indent_size = 4
