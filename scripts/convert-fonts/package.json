{
  "name": "font-converter",
  "version": "1.0.0",
  "description": "Conversor automatizado de fontes TTF para WOFF2 com otimização para web",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "convert": "node index.js",
    "convert:watch": "node index.js --watch",
    "generate-css": "node generate-css.js",
    "convert:full": "npm run convert && npm run generate-css"
  },
  "keywords": [
    "fonts",
    "ttf",
    "woff2",
    "conversion",
    "web-performance"
  ],
  "author": "Estúdio Entre",
  "license": "MIT",
  "dependencies": {
    "ttf2woff2": "^5.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "eslint": "^8.54.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
